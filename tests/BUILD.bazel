filegroup(
    name = "nsis_files",
    srcs = [
        "//tests/testdata:README.md",
    ],
)

nsis_component(
    name = "test_minimal_component",
    srcs = [":nsis_files"],
)

nsis_installer(
    name = "minimal_installer",
    components = [":test_minimal_component"],
    product = "Minimal Installer",
    product_path = "Minimal Installer",
)

